@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@implements IDisposable

<div class="page">
    <div class="sidebar">
        <NavMenu @rendermode="InteractiveWebAssembly" />
    </div>

    <main>


        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    // Check if the current URL contains "Account/Manage"
    private bool IsAccountManagePage =>
        NavigationManager.ToBaseRelativePath(NavigationManager.Uri).StartsWith("Account/Manage", StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        // Tell the layout to listen for URL changes so it can hide/show the bar dynamically
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        // Re-evaluate the page and update the layout
        StateHasChanged();
    }

    public void Dispose()
    {
        // Clean up the listener to prevent memory leaks
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}