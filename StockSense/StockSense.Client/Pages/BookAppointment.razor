@page "/appointment"
@layout EmptyLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Authorization
@using StockSense.shared
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http

@attribute [Authorize]

<div style="display: flex; gap: 40px; color: white; background: #111; padding: 20px; font-family: 'Segoe UI', sans-serif; min-height: 100vh;">

    @* --- LEFT SIDE: SELECTION --- *@
    <div style="flex: 2;">

        <div style="margin-bottom: 30px; background: #222; padding: 20px; border-radius: 8px; border: 1px solid #333;">
            <h2 style="margin-top: 0; margin-bottom: 15px; color: #fff;">Customer Details & Time</h2>

            <div style="display: flex; gap: 20px; margin-bottom: 20px;">
                <div style="flex: 1;">
                    <label style="display: block; margin-bottom: 5px; color: #aaa; font-size: 0.9em;">Selected Date</label>
                    <input type="date" @bind="newAppt.AppointmentDate" @bind:after="FetchBookedSlots"
                           style="width: 100%; padding: 12px; background: #111; color: white; border: 1px solid #444; border-radius: 5px;" />
                </div>
            </div>

            <div>
                <label style="display: block; margin-bottom: 10px; color: #aaa; font-size: 0.9em;">Select Available Time Slot</label>
                <div style="display: flex; flex-wrap: wrap; gap: 8px; max-height: 200px; overflow-y: auto; padding-right: 10px;">
                    @foreach (var time in availableTimeSlots)
                    {
                        bool isBooked = bookedTimeSlots.Contains(time);

                        <div @onclick="() => { if (!isBooked) SelectTimeSlot(time); }"
                             style="border: 1px solid @(newAppt.TimeSlot == time ? "white" : (isBooked ? "#222" : "#444"));
                                        background: @(newAppt.TimeSlot == time ? "white" : (isBooked ? "#222" : "#111"));
                                        color: @(newAppt.TimeSlot == time ? "black" : (isBooked ? "#555" : "white"));
                                        text-decoration: @(isBooked ? "line-through" : "none");
                                        cursor: @(isBooked ? "not-allowed" : "pointer");
                                        padding: 8px; border-radius: 4px; text-align: center; flex: 1 1 calc(16% - 10px); min-width: 75px; font-size: 0.85em; transition: 0.2s;">
                            @time
                        </div>
                    }
                </div>
            </div>
        </div>

        <h2 style="color: #fff; margin-bottom: 20px;">1. Select the services you want to avail</h2>

        @* --- CATEGORY FILTER BAR (Kept for functionality) --- *@
        <div style="margin-bottom: 25px; display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
            <span style="color: #888; font-size: 0.9em; margin-right: 5px;">Filter:</span>
            <button @onclick='() => selectedCategory = "All"'
                    style="padding: 6px 18px; border-radius: 20px; border: 1px solid #444;
                           background: @(selectedCategory == "All" ? "white" : "#111");
                           color: @(selectedCategory == "All" ? "black" : "white"); cursor: pointer; font-size: 0.85em; transition: 0.3s;">
                All
            </button>
            @foreach (var cat in availableServices.Select(s => s.Category).Distinct().OrderBy(c => c))
            {
                <button @onclick="() => selectedCategory = cat"
                        style="padding: 6px 18px; border-radius: 20px; border: 1px solid #444;
                                   background: @(selectedCategory == cat ? "white" : "#111");
                                   color: @(selectedCategory == cat ? "black" : "white"); cursor: pointer; font-size: 0.85em; text-transform: capitalize; transition: 0.3s;">
                    @cat
                </button>
            }
        </div>

        @if (showSuccessMessage)
        {
            <div style="background: rgba(76, 175, 80, 0.1); color: #4CAF50; font-weight: bold; margin-bottom: 15px; padding: 15px; border: 1px solid #4CAF50; border-radius: 5px;">
                Appointment booked successfully!
            </div>
        }
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="background: rgba(244, 67, 54, 0.1); color: #f44336; font-weight: bold; margin-bottom: 15px; padding: 15px; border: 1px solid #f44336; border-radius: 5px;">
                @errorMessage
            </div>
        }

        <div style="display: flex; flex-wrap: wrap; gap: 15px;">
            @if (!availableServices.Any())
            {
                <div style="color: gray; padding: 20px;">Loading services...</div>
            }
            else
            {
                @foreach (var service in FilteredServices)
                {
                    <div @onclick="() => ToggleService(service)"
                         style="border: 2px solid @(service.IsSelected ? "#d32f2f" : "#333");
                                        background: #222; padding: 15px; cursor: pointer; width: 220px; border-radius: 8px; transition: 0.3s; height: 120px; display: flex; flex-direction: column; justify-content: space-between;">

                        <div style="display: flex; justify-content: space-between; align-items: start;">
                            @* --- CATEGORY REMOVED FROM HERE --- *@
                            <strong style="font-size: 1.1em; color: white; width: 80%;">@service.Name</strong>
                            <input type="checkbox" checked="@service.IsSelected" style="accent-color: #d32f2f; pointer-events: none;" />
                        </div>

                        <div style="color: #81c784; font-weight: bold; font-size: 1.1em;">
                            ₱ @service.Price.ToString("N0")
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    @* --- RIGHT SIDE: SUMMARY --- *@
    <div style="flex: 1; background: #000; padding: 25px; border-radius: 12px; border: 1px solid #333; display: flex; flex-direction: column; position: sticky; top: 20px; height: fit-content;">
        <h2 style="margin-top: 0; color: #fff; border-bottom: 1px solid #333; padding-bottom: 10px;">3. Booking Summary</h2>

        <div style="margin: 15px 0;">
            <small style="color: #666; text-transform: uppercase;">Customer</small>
            <div style="font-weight: bold; color: #fff;">@newAppt.CustomerName</div>
        </div>

        <ul style="list-style: none; padding: 0; margin-top: 10px; flex-grow: 1;">
            @if (!SelectedServices.Any())
            {
                <li style="color: #555; font-style: italic;">No services selected yet.</li>
            }
            @foreach (var selected in SelectedServices)
            {
                <li style="display: flex; justify-content: space-between; margin-bottom: 12px; border-bottom: 1px solid #111; padding-bottom: 5px;">
                    <span style="font-size: 0.9em; color: #ccc;">@selected.Name</span>
                    <span style="font-weight: bold; color: #fff;">₱ @selected.Price.ToString("N0")</span>
                </li>
            }
        </ul>

        <div style="margin-top: 20px; background: #111; padding: 15px; border-radius: 8px;">
            <div style="display: flex; justify-content: space-between; font-weight: bold; font-size: 1.3em; color: #81c784;">
                <span>Total</span>
                <span>₱ @TotalPrice.ToString("N0")</span>
            </div>
        </div>

        <button @onclick="HandleSubmit"
                disabled="@isProcessing"
                style="width: 100%; margin-top: 20px; padding: 18px; background: @(isProcessing ? "#444" : "white"); color: black; font-weight: 800; border: none; border-radius: 8px; cursor: pointer; text-transform: uppercase; letter-spacing: 1px;">
            @if (isProcessing)
            {
                <span>Processing...</span>
            }
            else
            {

                <span>Confirm Booking</span>
            }
        </button>
    </div>

</div>

@code {
    private Appointment newAppt = new() { AppointmentDate = DateTime.Now, TimeSlot = "" };
    private bool showSuccessMessage = false;
    private bool isProcessing = false;
    private string errorMessage = "";
    private string selectedCategory = "All";

    public class ServiceOption
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public decimal Price { get; set; }
        public string Category { get; set; } = "General";
        public bool IsSelected { get; set; }
    }

    private List<ServiceOption> availableServices = new();
    private List<string> bookedTimeSlots = new();

    private List<string> availableTimeSlots = new()
    {
        "09:00", "09:15", "09:30", "09:45", "10:00", "10:15", "10:30", "10:45", "11:00",
        "13:00", "13:15", "13:30", "13:45", "14:00", "14:15", "14:30", "14:45", "15:00",
        "15:15", "15:30", "15:45", "16:00", "16:15", "16:30"
    };

    private IEnumerable<ServiceOption> FilteredServices =>
        selectedCategory == "All"
        ? availableServices
        : availableServices.Where(s => s.Category == selectedCategory);

    private IEnumerable<ServiceOption> SelectedServices => availableServices.Where(s => s.IsSelected);
    private decimal TotalPrice => SelectedServices.Sum(s => s.Price);

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await FetchBookedSlots();
        await LoadUserProfile();
        await LoadServices();
    }

    private async Task LoadUserProfile()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                try
                {
                    var profile = await Http.GetFromJsonAsync<UserProfile>("api/user/profile");
                    newAppt.CustomerName = profile != null ? $"{profile.FirstName} {profile.LastName}".Trim() : user.Identity.Name ?? "User";
                }
                catch { newAppt.CustomerName = user.Identity.Name ?? "User"; }
            }
        }
    }

    private async Task LoadServices()
    {
        try
        {
            var dbServices = await Http.GetFromJsonAsync<List<StoreService>>("api/services");
            if (dbServices != null)
            {
                availableServices = dbServices.Select(s => new ServiceOption
                {
                    Id = s.Id,
                    Name = s.Name,
                    Price = s.Price,
                    Category = s.Category,
                    IsSelected = false
                }).ToList();
            }
        }
        catch { errorMessage = "Failed to load services."; }
    }

    private async Task FetchBookedSlots()
    {
        try
        {
            var dateStr = newAppt.AppointmentDate.ToString("yyyy-MM-dd");
            var slots = await Http.GetFromJsonAsync<List<string>>($"api/appointments/booked-slots?date={dateStr}");
            bookedTimeSlots = slots ?? new();
        }
        catch { Console.WriteLine("Booking fetch failed."); }
    }

    private void SelectTimeSlot(string time)
    {
        newAppt.TimeSlot = time;
        errorMessage = "";
    }

    private void ToggleService(ServiceOption service)
    {
        service.IsSelected = !service.IsSelected;
        showSuccessMessage = false;
        errorMessage = "";
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrEmpty(newAppt.TimeSlot)) { errorMessage = "Please select a time slot."; return; }
        if (!SelectedServices.Any()) { errorMessage = "Please select at least one service."; return; }

        isProcessing = true;
        newAppt.ServicesRequested = string.Join(", ", SelectedServices.Select(s => s.Name));
        newAppt.TotalAmount = TotalPrice;
        newAppt.Category = SelectedServices.FirstOrDefault()?.Category ?? "General";

        try
        {
            var response = await Http.PostAsJsonAsync("api/appointments", newAppt);
            if (response.IsSuccessStatusCode)
            {
                showSuccessMessage = true;
                errorMessage = "";
                newAppt = new() { AppointmentDate = DateTime.Now, CustomerName = newAppt.CustomerName };
                availableServices.ForEach(s => s.IsSelected = false);
                await FetchBookedSlots();
            }
            else
            {
                errorMessage = "Booking failed.";
            }
        }
        catch { errorMessage = "Connection error."; }
        finally { isProcessing = false; }
    }
}