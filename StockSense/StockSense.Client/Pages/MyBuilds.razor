@page "/my-builds"
@layout EmptyLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using StockSense.Shared
@using System.Text.Json
@using System.Globalization
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav

<div class="customer-container">
    <div class="header-section">
        <h2>My Build History</h2>
        <p style="color: #888;">Track the status of your submitted custom builds.</p>
    </div>

    @if (isLoading)
    {
        <div style="color: gray;">Loading your builds...</div>
    }
    else if (myBuilds == null || !myBuilds.Any())
    {
        <div style="background: #1e1e1e; padding: 30px; border-radius: 8px; text-align: center; border: 1px solid #333;">
            <h3 style="color: #ccc;">You haven't submitted any builds yet.</h3>
            <button @onclick='() => Nav.NavigateTo("/build")' style="margin-top: 15px; padding: 10px 20px; background: #ff3e3e; color: white; border: none; border-radius: 5px; cursor: pointer;">Start a New Build</button>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table-dark">
                <thead>
                    <tr>
                        <th style="width: 25%;">Date Submitted</th>
                        <th style="width: 20%;">Items</th>
                        <th style="width: 20%;">Total Value</th>
                        <th style="width: 20%;">Status</th>
                        <th style="width: 15%;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var build in myBuilds)
                    {
                        var parts = ParseParts(build.SelectedPartsJson);
                        var totalPrice = parts.Sum(p => p.Price);

                        <tr class="table-row">
                            <td class="date">@build.CreatedAt.ToString("MMM dd, yyyy h:mm tt")</td>

                            <td><span class="item-count">@parts.Count items</span></td>

                            <td class="price">@totalPrice.ToString("C0", CultureInfo.CreateSpecificCulture("en-PH"))</td>

                            <td>
                                <span class="status-badge @GetStatusClass(build.Status)">
                                    @build.Status
                                </span>
                            </td>
                            <td>
                                <button class="btn-view" @onclick="() => OpenModal(build, parts)">
                                    <span class="icon">👁</span> View
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @* --- MODAL FOR VIEWING DETAILS (Same as Admin) --- *@
    @if (ShowModal && CurrentParts != null)
    {
        <div class="modal-backdrop" @onclick="CloseModal">
            <div class="modal-content" @onclick:stopPropagation>
                <div class="modal-header">
                    <div>
                        <h3>Build Details</h3>
                        <span class="modal-date">Submitted: @CurrentBuild?.CreatedAt.ToString("f")</span>
                    </div>
                    <button class="close-btn" @onclick="CloseModal">×</button>
                </div>

                <div class="modal-body">
                    @foreach (var group in CurrentParts.GroupBy(p => p.Category))
                    {
                        <div class="category-section">
                            <h4 class="category-header">@group.Key</h4>
                            @foreach (var part in group)
                            {
                                <div class="part-item">
                                    <div class="part-details">
                                        <span class="brand-tag">@part.Brand</span>
                                        <span class="part-name">@part.Name</span>
                                    </div>
                                    <div class="part-price">
                                        @part.Price.ToString("C0", CultureInfo.CreateSpecificCulture("en-PH"))
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="modal-footer">
                    <div class="total-summary">
                        <span>Grand Total:</span>
                        <span class="total-amount">@CurrentParts.Sum(p => p.Price).ToString("C0", CultureInfo.CreateSpecificCulture("en-PH"))</span>
                    </div>
                    <button class="btn-close" @onclick="CloseModal">Close</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }
    private List<BuildRequest>? myBuilds;
    private bool isLoading = true;

    // Modal State
    private bool ShowModal = false;
    private BuildRequest? CurrentBuild;
    private List<Product> CurrentParts = new List<Product>();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask!;
        if (authState.User.Identity == null || !authState.User.Identity.IsAuthenticated)
        {
            Nav.NavigateTo($"/Account/Login?returnUrl={Uri.EscapeDataString(Nav.Uri)}", true);
            return;
        }

        var userName = authState.User.Identity.Name;

        try
        {
            // Call the new endpoint using the logged-in user's name
            myBuilds = await Http.GetFromJsonAsync<List<BuildRequest>>($"api/builds/customer/{userName}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading builds: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private List<Product> ParseParts(string json)
    {
        if (string.IsNullOrWhiteSpace(json) || json == "[]") return new List<Product>();
        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            return JsonSerializer.Deserialize<List<Product>>(json, options) ?? new List<Product>();
        }
        catch { return new List<Product>(); }
    }

    private void OpenModal(BuildRequest build, List<Product> parts)
    {
        CurrentBuild = build;
        CurrentParts = parts;
        ShowModal = true;
    }

    private void CloseModal() => ShowModal = false;

    private string GetStatusClass(string status) => status?.ToLower() switch
    {
        "pending" => "status-pending",
        "confirmed" => "status-confirmed",
        "completed" => "status-completed",
        "cancelled" => "status-cancelled",
        _ => "status-pending"
    };
}

<style>
