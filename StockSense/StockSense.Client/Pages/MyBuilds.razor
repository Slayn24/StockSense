    }

    .modal-content {
        background: #111;
        width: 600px;
        max-width: 90%;
        max-height: 85vh;
        border-radius: 12px;
        border: 1px solid #333;
        display: flex;
        flex-direction: column;
    }

    .modal-header {
        padding: 20px;
        border-bottom: 1px solid #333;
        display: flex;
        justify-content: space-between;
        align-items: start;
        background: #1a1a1a;
        border-radius: 12px 12px 0 0;
    }

        .modal-header h3 {
            margin: 0;
            font-size: 1.2rem;
            color: #fff;
        }

